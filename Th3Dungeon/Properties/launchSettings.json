{
  "profiles": {
    "Client": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "$(VINTAGE_STORY_MODDING)/Vintagestory.dll --tracelog --addModPath $(ProjectDir)/bin/$(Configuration)/Mods --addOrigin $(ProjectDir)/assets --dataPath $(VINTAGE_STORY_DATA_MODDING)",
      "workingDirectory": "$(VINTAGE_STORY_MODDING)"
    },
    "Server": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "$(VINTAGE_STORY_PRE)/VintagestoryServer.dll --tracelog --addModPath $(ProjectDir)/bin/$(Configuration)/Mods --addOrigin $(ProjectDir)/assets --dataPath $(VINTAGE_STORY_SERVER_DATA_MODDING)",
      "workingDirectory": "$(VINTAGE_STORY_MODDING)"
    }
  }
}